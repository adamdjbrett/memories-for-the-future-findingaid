---
layout: base.njk
---
<main data-pagefind-body data-pagefind-weight="10">
<div style="display:none" aria-hidden="true">
<span data-pagefind-meta="content_type">page</span>
<span data-pagefind-meta="search_priority">1</span>
<span data-pagefind-meta="source_file">{{ page.fileSlug }}.md</span>
<span data-pagefind-meta="title">{{ title or page.fileSlug }} — {{ page.fileSlug }}.md</span>
</div>
{{ content | safe }}
</main>
